# textreflex configuration — all optional. The app is keyless and needs none of
# this to run.

# Per-call timeout in seconds (default 90).
AI_TIMEOUT=90

# How many times to retry a busy/failed free endpoint before giving up (default 3).
AI_RETRIES=3

# Optional: a Pollinations token ONLY raises the free rate limits. The app works
# without it. Never required.
POLLINATIONS_TOKEN=

# Optional model override (comma-separated, tried in order).
# POLLINATIONS_MODEL=openai-fast,openai

# Flask debug mode (development only).
FLASK_DEBUG=false
